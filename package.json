{
  "name": "@theredhead/fetchlane-navigator",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:clean": "rm -f package-lock.json && npm cache clean --force && rm -rf node_modules .angular && npm install && ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:demo": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.demo.yml up --build -d",
    "docker:demo:down": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.demo.yml down"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/cdk": "21.1.0",
    "@angular/common": "21.1.0",
    "@angular/compiler": "21.1.0",
    "@angular/core": "21.1.0",
    "@angular/forms": "21.1.0",
    "@angular/platform-browser": "21.1.0",
    "@angular/router": "21.1.0",
    "@theredhead/lucid-blocks": "^0.1.0",
    "@theredhead/lucid-forms": "^0.1.0",
    "@theredhead/lucid-foundation": "^0.1.0",
    "@theredhead/lucid-kit": "^0.1.0",
    "@theredhead/lucid-theme": "^0.1.0",
    "keycloak-js": "^26.2.3",
    "rxjs": "~7.8.0",
    "swagger-ui-dist": "^5.32.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.2",
    "@analogjs/vitest-angular": "^2.4.2",
    "@angular/build": "21.1.0",
    "@angular/cli": "21.1.0",
    "@angular/compiler-cli": "21.1.0",
    "@types/node": "^25.5.2",
    "@types/swagger-ui-dist": "^3.30.6",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
